# FabLab Suite - Ubuntu installer config (monorepo)
# Copy to fabsuite-ubuntu.env then adjust values.

# Monorepo Git URL (source unique de mise à jour)
GIT_REPO_URL=https://github.com/fablabloritz-coder/Fablab-Suite.git
GIT_BRANCH=main

# Target folder where the monorepo is cloned on the server
INSTALL_DIR=$HOME/fablab-suite

# Apps managed by the helper script (space-separated)
APPS="FabHome Fabtrack PretGo FabBoard"

# Shared runtime settings
TZ=Europe/Paris
FLASK_SECRET_KEY=

# Published ports
FABHOME_PORT=3001
FABTRACK_PORT=5555
PRETGO_PORT=5000
FABBOARD_PORT=5580

# Optional overrides for inter-app URLs used by FabBoard.
# Leave empty to let the helper auto-compute with server hostname.
FABTRACK_URL=
PRETGO_URL=

# Optional custom volume paths (uncomment if needed)
# FABTRACK_DATA_PATH=./docker-data/data
# FABTRACK_UPLOADS_PATH=./docker-data/uploads
# PRETGO_DATA_PATH=./docker-data/data
# PRETGO_UPLOADS_PATH=./docker-data/uploads/materiel
# FABBOARD_DATA_PATH=./docker-data/data
