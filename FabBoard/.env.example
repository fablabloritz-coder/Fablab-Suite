# FabBoard — Variables d'environnement
# Copiez ce fichier en .env et ajustez les valeurs
#   cp .env.example .env   (Linux/macOS)
#   copy .env.example .env  (Windows)

# Fuseau horaire
TZ=Europe/Paris

# Port d'écoute (modifiez si le port 5580 est déjà utilisé)
FABBOARD_PORT=5580

# Clé secrète Flask (laisser vide = générée automatiquement)
# Recommandé en production : python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# ─────────────────────────────────────────
#  Interconnexion avec Fabtrack
#  En déploiement serveur, remplacez par l'IP ou hostname du serveur Fabtrack
# ─────────────────────────────────────────
FABTRACK_URL=http://host.docker.internal:5555

# ─────────────────────────────────────────
#  Sources optionnelles
# ─────────────────────────────────────────

# Repetier Server (imprimantes 3D)
# REPETIER_URL=http://192.168.1.100:3344
# REPETIER_APIKEY=

# Nextcloud CalDAV (calendrier)
# NEXTCLOUD_CALDAV_URL=https://votre-nextcloud.com/remote.php/dav
# NEXTCLOUD_USER=fablab
# NEXTCLOUD_PASS=motdepasse
# NEXTCLOUD_CALENDAR_NAME=fablab

# PrusaLink (optionnel, séparer par virgule si plusieurs imprimantes)
# PRUSALINK_URLS=
# PRUSALINK_APIKEYS=

# Chemin des données (optionnel — valeur par défaut si non renseigné)
# FABBOARD_DATA_PATH=./docker-data/data
